  double calcularMedia(double n1, double n2, double n3) {
    return (n1 + n2 + n3) / 3;
  }

  // você pode alterar as notas aqui
  double nota1 = 7.5;
  double nota2 = 6.0;
  double nota3 = 8.0;

  double media = calcularMedia(nota1, nota2, nota3);

  print("Média: $media");

  if (media >= 7) {
    print("Aprovado");
  } else {
    print("Reprovado") ;
 
  }
